---
import Base from '../layouts/Base.astro';
---

<Base
  title="Resume — Jinit Shah"
  description="Resume of Jinit Shah — senior software engineer. View online or download as PDF."
  current="/resume"
  headerOn="dark"
>
  <section class="section theme-black-bold resume-hero centered">
    <div class="section__inner">
      <h1>Resume</h1>
      <p><a href="/s/Resume_JinitShah.pdf">pdf</a></p>
    </div>
  </section>

  <section class="section theme-light-bold">
    <div class="section__inner">
      <a class="resume-frame" href="/s/Resume_JinitShah.pdf" aria-label="Open resume PDF">
        <img src="/img/resume.jpg" width="1313" height="1700" alt="Resume of Jinit Shah" />
      </a>
    </div>
  </section>
</Base>
